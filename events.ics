---
layout: null
permalink: /events.ics
---
{%- comment -%}Combined ICS calendar feed for all events{%- endcomment -%}
BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//{{ site.title }}//EN
X-WR-CALNAME:{{ site.title }} Events
METHOD:PUBLISH
{%- for e in site.events %}
{%- if e.start_date -%}
  {%- assign ics_start = e.start_date | date: "%Y%m%d" -%}
{%- else -%}
  {%- assign ics_start = e.date | date: "%Y%m%d" -%}
{%- endif -%}
{%- assign end_epoch = e.date | date: "%s" | plus: 86400 -%}
{%- assign ics_end = end_epoch | date: "%Y%m%d" -%}
{%- assign ics_title = e.title | strip_html | strip_newlines -%}
{%- assign ics_uid = e.slug | append: "@" | append: site.url | remove: "https://" | remove: "http://" -%}
{%- assign body_text = e.content | strip_html | strip_newlines | strip | truncate: 500, '...' -%}
{%- capture ics_desc -%}
{%- if e.summary %}{{ e.summary | strip_html | strip_newlines }}{% endif -%}
{%- if e.summary and body_text %}\n\n{% endif -%}
{%- if body_text %}{{ body_text }}{% endif -%}
{%- if e.web-page %}\n\nExternal link: {{ e.web-page }}{% endif -%}
{%- endcapture %}
BEGIN:VEVENT
DTSTART;VALUE=DATE:{{ ics_start }}
DTEND;VALUE=DATE:{{ ics_end }}
SUMMARY:{{ ics_title }}
{%- if ics_desc != blank %}
DESCRIPTION:{{ ics_desc | strip_newlines }}
{%- endif %}
{%- if e.location %}
LOCATION:{{ e.location | strip_html | strip_newlines }}
{%- endif %}
URL:{{ site.url }}{{ e.url }}
UID:{{ ics_uid }}
END:VEVENT
{%- endfor %}
END:VCALENDAR
